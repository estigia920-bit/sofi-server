#!/bin/bash

conjunto -e

# Analizar argumentos de la línea de comandos
TARGET="$1" # Parámetro de destino opcional

# Validar el objetivo si se proporciona
si [[ -n "$OBJETIVO" ]] && [[ ! "$TARGET" =~ ^(estable|último|[0-9]+\.[0-9]+\.[0-9]+(-[^[:espacio:]]+)?)$ ]]; entonces
    echo "Uso: $0 [estable|última|VERSIÓN]" >&2
    salida 1
fi

GCS_BUCKET="https://storage.googleapis.com/claude-code-dist-86c565f3-f756-42ad-8dfa-d59b1c096819/claude-code-releases"
DOWNLOAD_DIR="$HOME/.claude/descargas"

# Verifique las dependencias requeridas
DESCARGADOR=""
si comando -v curl >/dev/null 2>&1; entonces
    DESCARGADOR="curl"
comando elif -v wget >/dev/null 2>&1; entonces
    DESCARGADOR="wget"
else
    echo "Se requiere curl o wget pero ninguno está instalado" >&2
    salida 1
fi

# Comprueba si jq está disponible (opcional)
HAS_JQ=falso
si comando -v jq >/dev/null 2>&1; entonces
    HAS_JQ=verdadero
fi

# Función de descarga que funciona tanto con curl como con wget
descargar_archivo() {
    URL local="$1"
    salida local="$2"
    
    si [ "$DOWNLOADER" = "curl" ]; entonces
        si [ -n "$salida" ]; entonces
            curl -fsSL -o "$salida" "$url"
        else
            curl -fsSL "$url"
        fi
    elif [ "$DOWNLOADER" = "wget" ]; entonces
        si [ -n "$salida" ]; entonces
            wget -q -O "$salida" "$url"
        else
            wget -q -O - "$url"
        fi
    else
        retorno 1
    fi
}

# Analizador JSON simple para extraer suma de comprobación cuando jq no está disponible
obtener_suma_de_manifiesto() {
    json local="$1"
    plataforma local="$2"
    
    # Normalizar JSON a una sola línea y extraer suma de comprobación
    json=$(echo "$json" | tr -d '\n\r\t' | sed 's/ \+/ /g')
    
    # Extraer suma de comprobación para la plataforma usando bash regex
    si [[ $json =~ \"$platform\"[^}]*\"checksum\"[[:espacio:]]*:[[:espacio:]]*\"([a-f0-9]{64})\" ]]; entonces
        echo "${BASH_REMATCH[1]}"
        retorno 0
    fi
    
    retorno 1
}

# Detectar plataforma
caso "$(uname -s)" en
    Darwin) os="darwin" ;;
    Linux) os="linux" ;;
    MINGW*|MSYS*|CYGWIN*) echo "Este script no admite Windows. Consulte https://code.claude.com/docs para conocer las opciones de instalación." >&2; salida 1 ;;
    *) echo "Sistema operativo no compatible: $(uname -s). Consulte https://code.claude.com/docs para conocer las plataformas compatibles." >&2; salida 1 ;;
esac

caso "$(uname -m)" en
    x86_64|amd64) arch="x64" ;;
    arm64|aarch64) arch="arm64" ;;
    *) echo "Arquitectura no compatible: $(uname -m)" >&2; salida 1 ;;
esac

# Detectar Rosetta 2 en macOS: si el shell se ejecuta como x64 bajo Rosetta en una Mac ARM,
# descarga el binario nativo arm64 en lugar del x64
si [ "$os" = "darwin" ] && [ "$arch" = "x64" ]; entonces
    si [ "$(sysctl -n sysctl.proc_translated 2>/dev/null)" = "1" ]; entonces
        arco="brazo64"
    fi
fi

# Verifique musl en Linux y ajuste la plataforma en consecuencia
si [ "$os" = "linux" ]; entonces
    si [ -f/lib/libc.musl-x86_64.so.1 ] || [ -f/lib/libc.musl-aarch64.so.1 ] || ldd/bin/ls 2>&1 | grep -q musl; entonces
        plataforma="linux-${arch}-musl"
    else
        plataforma="linux-${arch}"
    fi
else
    plataforma="${os}-${arch}"
fi
mkdir -p "$DOWNLOAD_DIR"

# Descargue siempre la última versión (que tiene el instalador más actualizado)
versión=$(descargar_archivo "$GCS_BUCKET/latest")

# Descargar manifiesto y extraer suma de comprobación
manifest_json=$(descargar_archivo "$GCS_BUCKET/$version/manifest.json")

# Utilice jq si está disponible; de lo contrario, vuelva al análisis bash puro
si [ "$HAS_JQ" = verdadero ]; entonces
    suma de comprobación=$(echo "$manifest_json" | jq -r ".platforms[\"$platform\"].checksum // vacío")
else
    suma de comprobación=$(get_checksum_from_manifest "$manifest_json" "$plataforma")
fi

# Validar formato de suma de comprobación (SHA256 = 64 caracteres hexadecimales)
si [ -z "$checksum" ] || [[ ! "$checksum" =~ ^[af0-9]{64}$ ]]; entonces
    echo "Plataforma $plataforma no encontrada en el manifiesto" >&2
    salida 1
fi

# Descargar y verificar
ruta_binaria="$DOWNLOAD_DIR/claude-$version-$platform"
si ! descargar_archivo "$GCS_BUCKET/$version/$platform/claude" "$binary_path"; entonces
    echo "Error en la descarga" >&2
    rm -f "$ruta_binaria"
    salida 1
fi

# Elija la herramienta de suma de comprobación correcta
si [ "$os" = "darwin" ]; entonces
    actual=$(shasum -a 256 "$binary_path" | corte -d' ' -f1)
else
    actual=$(sha256sum "$binary_path" | corte -d' ' -f1)
fi

si [ "$actual" != "$checksum" ]; entonces
    echo "Error en la verificación de suma de comprobación" >&2
    rm -f "$ruta_binaria"
    salida 1
fi

chmod +x "$ruta_binaria"

# Ejecute claude install para configurar el iniciador y la integración del shell
echo "Configuración del código Claude..."
"$binary_path" instalar ${TARGET:+"$TARGET"}

# Limpiar el archivo descargado
rm -f "$ruta_binaria"

eco ""
echo "âœ… ¡Instalación completa!"
eco ""