<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SOFI - Proyección Cerebral 3D</title>
    <script src="https://cdn.jsdelivr.net/npm/three@0.150.1/build/three.min.js"></script> <!-- Para gráficos 3D -->
    <script src="/socket.io/socket.io.js"></script> <!-- Conexión con servidor -->
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: Arial, sans-serif; }
        body { background: #0a0a1a; color: white; }
        
        /* Contenedor principal */
        #contenedor-general {
            display: flex;
            flex-wrap: wrap;
            width: 100vw;
            height: 100vh;
        }

        /* Panel de datos del usuario */
        #panel-usuario {
            width: 25%;
            background: #121224;
            padding: 20px;
            border-right: 2px solid #3498DB;
        }

        #panel-usuario h2 { color: #3498DB; margin-bottom: 20px; }
        #datos-usuario p { margin: 10px 0; }
        #actualizaciones { margin-top: 30px; }
        .actualizacion { color: #2ECC71; margin: 5px 0; }
        .acceso-permitido { color: #2ECC71; font-weight: bold; }
        .acceso-denegado { color: #FF5733; font-weight: bold; }

        /* Área de proyección 3D */
        #proyeccion-3d {
            width: 75%;
            height: 100vh;
            position: relative;
        }

        /* Adaptación para móviles */
        @media (max-width: 768px) {
            #contenedor-general { flex-direction: column; }
            #panel-usuario, #proyeccion-3d { width: 100%; height: 50vh; }
        }
    </style>
</head>
<body>
    <div id="contenedor-general">
        <!-- Panel de datos del usuario -->
        <div id="panel-usuario">
            <h2>🧠 DATOS DE USUARIO</h2>
            <div id="datos-usuario" style="display: none;">
                <p><strong>ID:</strong> <span id="id-usuario"></span></p>
                <p><strong>Frecuencia base:</strong> 12.3 Hz</p>
                <p><strong>Dispositivo:</strong> <span id="dispositivo-usuario"></span></p>
            </div>

            <!-- Actualizaciones en tiempo real -->
            <div id="actualizaciones">
                <h3>ESTADO DE ACCESO</h3>
                <div id="estado-seguridad" class="acceso-denegado">Validando credenciales...</div>
            </div>
        </div>

        <!-- Área de proyección 3D -->
        <div id="proyeccion-3d"></div>
    </div>

    <script>
        // CONFIGURACIÓN DE SEGURIDAD - CAMBIA ESTA LLAVE POR LA MISMA QUE EN TU SERVIDOR
        const LLAVE_SOFI = "tu-llave-secreta-personalizada-aqui";
        const socket = io();

        // Enviar llave para validar acceso al conectarse
        socket.emit('validar-llave-sofi', LLAVE_SOFI);

        // Variables para la escena 3D
        let escena, camara, renderizador, cerebro3D, zonasNeuronales = {};

        // Función para inicializar la proyección 3D
        function initEscena3D() {
            // Escena
            escena = new THREE.Scene();
            escena.background = new THREE.Color(0x0a0a1a);

            // Cámara
            camara = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
            camara.position.z = 5;

            // Renderizador
            renderizador = new THREE.WebGLRenderer();
            renderizador.setSize(window.innerWidth * 0.75, window.innerHeight);
            document.getElementById('proyeccion-3d').appendChild(renderizador.domElement);

            // Crear geometría del cerebro
            const geometriaCerebro = new THREE.SphereGeometry(1.5, 32, 32);
            const materialBase = new THREE.MeshBasicMaterial({ 
                color: 0x3498DB, 
                wireframe: true, 
                transparent: true,
                opacity: 0.7
            });
            cerebro3D = new THREE.Mesh(geometriaCerebro, materialBase);
            escena.add(cerebro3D);

            // Zonas neuronales
            zonasNeuronales = {
                motor: new THREE.Mesh(new THREE.SphereGeometry(0.2, 16, 16), new THREE.MeshBasicMaterial({ color: 0xFF5733 })),
                cognitiva: new THREE.Mesh(new THREE.SphereGeometry(0.2, 16, 16), new THREE.MeshBasicMaterial({ color: 0x3498DB })),
                sensorial: new THREE.Mesh(new THREE.SphereGeometry(0.2, 16, 16), new THREE.MeshBasicMaterial({ color: 0x2ECC71 }))
            };
            zonasNeuronales.motor.position.set(0.5, 0.5, 0.5);
            zonasNeuronales.cognitiva.position.set(-0.5, -0.5, 0.5);
            zonasNeuronales.sensorial.position.set(0.5, -0.5, -0.5);
            Object.values(zonasNeuronales).forEach(zona => escena.add(zona));

            // Animar escena
            function animate() {
                requestAnimationFrame(animate);
                cerebro3D.rotation.x += 0.005;
                cerebro3D.rotation.y += 0.005;
                renderizador.render(escena, camara);
            }
            animate();
        }

        // Manejar respuesta de acceso permitido
        socket.on('bienvenida', data => {
            document.getElementById('estado-seguridad').className = 'acceso-permitido';
            document.getElementById('estado-seguridad').textContent = "✅ ACCESO PERMITIDO - SOFI ACTIVA";
            document.getElementById('datos-usuario').style.display = "block";
            initEscena3D();
        });

        // Manejar datos del usuario
        socket.on('proyeccionCerebro', data => {
            document.getElementById('id-usuario').textContent = data.idUsuario || "USUARIO_SOFI";
            document.getElementById('dispositivo-usuario').textContent = data.dispositivo || "CONECTADO";
        });

        // Manejar actualizaciones en tiempo real
        socket.on('actualizacionTiempoReal', data => {
            // Mostrar mensaje de actualización
            const div = document.createElement('div');
            div.className = 'actualizacion';
            div.textContent = `${data.tiempo}: Zona ${data.zona} activa`;
            document.getElementById('actualizaciones').appendChild(div);

            // Actualizar visualización de zona neuronal
            Object.values(zonasNeuronales).forEach(zona => zona.visible = false);
            if (data.zona.includes("Motora")) zonasNeuronales.motor.visible = true;
            if (data.zona.includes("Cognitiva")) zonasNeuronales.cognitiva.visible = true;
            if (data.zona.includes("Sensorial")) zonasNeuronales.sensorial.visible = true;
        });

        // Manejar acceso denegado o desconexión
        socket.on('disconnect', () => {
            document.getElementById('estado-seguridad').className = 'acceso-denegado';
            document.getElementById('estado-seguridad').textContent = "❌ ACCESO DENEGADO - LLAVE INCORRECTA O SERVICIO NO DISPONIBLE";
            document.getElementById('datos-usuario').style.display = "none";
        });

        // Ajustar tamaño al cambiar ventana
        window.addEventListener('resize', () => {
            if (camara && renderizador) {
                camara.aspect = window.innerWidth * 0.75 / window.innerHeight;
                camara.updateProjectionMatrix();
                renderizador.setSize(window.innerWidth * 0.75, window.innerHeight);
            }
        });
    </script>
</body>
</html>
