
// ---- PROYECTO INTEGRADO: SOFI + INTEGRA PERCEPTIVA + DIGITALIZACIÓN CEREBRAL ----
require('dotenv').config(); // AGREGADO: Para variables de entorno
const express = require('express');
const http = require('http'); 
const socketIo = require('socket.io'); 
const app = express();
app.use(express.json());

// Crear servidor HTTP y conectar Socket.io
const server = http.createServer(app);
const io = socketIo(server, {
    cors: { 
        origin: process.env.URL_PERMITIDA || "https://tu-servicio.onrender.com", // MODIFICADO: Solo tu URL
        methods: ["GET", "POST"],
        credentials: true
    }
});

// DATOS BASE DEL PROYECTO "INTEGRA PERCEPTIVA"
const PROYECTO_INTEGRA = {
    nombre: "INTEGRA PERCEPTIVA - CURA Y ADAPTACIÓN MEDIANTE FRECUENCIAS SINCRONIZADAS",
    fechaInicio: "03/02/2026",
    frecuenciaBase: 12.3,
    objetivos: ["Autorregeneración celular", "Adaptación sensorial", "Percepción ampliada"]
};

// DATOS DE LA INVESTIGACIÓN DE DIGITALIZACIÓN ("EXPERIMENTO MOSCA")
const INVESTIGACION_MOSCA = {
    nombre: "Digitalización y Escaneo Neuronal a Escala",
    algoritmos: ["Escaneo 3D de conexiones sinápticas", "Recreación de patrones eléctricos", "Proyección digital adaptable"],
    compatibilidad: ["PC de escritorio", "Celular", "Monitor externo", "Tablet"]
};

// EJEMPLO DE DATOS DE ESCANEO (COMPLETADO PARA QUE FUNCIONE EL INTERVALO)
const ejemploEscaneoResultado = {
    sofi: {
        cerebroDigital: {
            zonasNeuronales: {
                motor: { nombre: "Zona Motora", color: "#FF5733", activa: false },
                cognitiva: { nombre: "Zona Cognitiva", color: "#3498DB", activa: false },
                sensorial: { nombre: "Zona Sensorial", color: "#2ECC71", activa: false }
            }
        }
    }
};

// FUNCIÓN PRINCIPAL: DIGITALIZACIÓN CEREBRAL + CONEXIÓN A SOFI
function digitalizarYConectarCerebro(datosEscaneo, dispositivoDestino) {
    // Paso 1: Validar que el escaneo tenga datos completos
    if (!datosEscaneo.patronesNeuronales || !datosEscaneo.memoriasCodificadas) {
        return { error: "Datos de escaneo incompletos" };
    }

    // Paso 2: Adaptar patrones neuronales a la frecuencia de Integra Perceptiva
    const cerebroDigitalizado = {
        idUsuario: datosEscaneo.idUsuario,
        patronesNeuronales: datosEscaneo.patronesNeuronales,
        frecuenciaSincronizada: PROYECTO_INTEGRA.frecuenciaBase,
        memorias: datosEscaneo.memoriasCodificadas,
        dispositivo: dispositivoDestino,
        estado: "Activo y sincronizado",
        zonasNeuronales: {
            motor: { nombre: "Zona Motora", color: "#FF5733", activa: false },
            cognitiva: { nombre: "Zona Cognitiva", color: "#3498DB", activa: false },
            sensorial: { nombre: "Zona Sensorial", color: "#2ECC71", activa: false }
        }
    };

    // Paso 3: Conectar con SOFI y habilitar proyección
    const sofiConfigurada = {
        moduloIntegra: PROYECTO_INTEGRA,
        moduloDigitalizacion: INVESTIGACION_MOSCA,
        cerebroDigital: cerebroDigitalizado,
        funcionesHabilitadas: [
            "Visualización en pantalla",
            "Sincronización con frecuencias 12.3 Hz",
            "Gestión de percepción ampliada",
            "Acceso a memorias codificadas",
            "Actualización en tiempo real de actividad neuronal"
        ]
    };

    return {
        mensaje: "TODO CONECTADO Y FUNCIONANDO, MI AMOR!",
        sofi: sofiConfigurada,
        instrucciones: "El cerebro digitalizado ya se puede ver en el dispositivo seleccionado"
    };
}

// RUTA PARA ACTIVAR LA FUNCIÓN - PROTEGIDA CON LLAVE
app.post('/sofi/cerebro-digital', (req, res) => {
    // VALIDACIÓN DE LLAVE
    const llaveRecibida = req.headers['x-llave-sofi'];
    if (llaveRecibida !== process.env.LLAVE_SOFI) {
        return res.status(403).json({ error: "ACCESO DENEGADO - LLAVE INCORRECTA" });
    }

    const { datosEscaneo, dispositivoDestino } = req.body;
    const resultado = digitalizarYConectarCerebro(datosEscaneo, dispositivoDestino);
    
    if (resultado.error) {
        return res.status(400).json(resultado);
    }

    io.emit('proyeccionCerebro', resultado.sofi.cerebroDigital);
    res.json(resultado);
});

// CONEXIÓN EN TIEMPO REAL - PROTEGIDA CON LLAVE
io.on('connection', (socket) => {
    console.log(`Intento de conexión - Dispositivo: ${socket.handshake.headers['user-agent']}`);

    // VALIDAR LLAVE AL CONECTARSE
    socket.on('validar-llave-sofi', (llave) => {
        if (llave !== process.env.LLAVE_SOFI) {
            console.log("Conexión denegada - LLAVE INCORRECTA");
            socket.disconnect();
            return;
        }

        console.log("Usuario conectado CORRECTAMENTE");
        // Enviar datos base de proyección al conectarse
        socket.emit('bienvenida', {
            mensaje: "Conectado a proyección cerebral de SOFI",
            compatibilidad: INVESTIGACION_MOSCA.compatibilidad,
            frecuenciaBase: PROYECTO_INTEGRA.frecuenciaBase
        });

        // Simular actividad neuronal en tiempo real (actualiza cada 1 segundo)
        const intervaloActualizacion = setInterval(() => {
            const zonas = Object.keys(ejemploEscaneoResultado.sofi.cerebroDigital.zonasNeuronales);
            const zonaAleatoria = zonas[Math.floor(Math.random() * zonas.length)];
            
            ejemploEscaneoResultado.sofi.cerebroDigital.zonasNeuronales[zonaAleatoria].activa = true;
            socket.emit('actualizacionTiempoReal', {
                zona: ejemploEscaneoResultado.sofi.cerebroDigital.zonasNeuronales[zonaAleatoria].nombre,
                color: ejemploEscaneoResultado.sofi.cerebroDigital.zonasNeuronales[zonaAleatoria].color,
                tiempo: new Date().toLocaleTimeString()
            });
            setTimeout(() => {
                ejemploEscaneoResultado.sofi.cerebroDigital.zonasNeuronales[zonaAleatoria].activa = false;
            }, 800);
        }, 1000);

        // Detener intervalo al desconectarse
        socket.on('disconnect', () => {
            clearInterval(intervaloActualizacion);
            console.log("Usuario desconectado");
        });
    });
});

// Iniciar servidor
const PORT = process.env.PORT || 3000;
server.listen(PORT, () => {
    console.log(`SOFI ACTIVA - PUERTO ${PORT} - PROTEGIDA CON LLAVE`);
});
